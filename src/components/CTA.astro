<section id="contact" class="relative py-32 overflow-hidden">
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, #4207C5 0%, #1a0768 45%, #040223 90%);"></div>
  <div class="absolute inset-0 bg-grid bg-grid-fade"></div>

  {/* Floating accents */}
  <div class="absolute top-20 left-[10%] w-6 h-6 bg-aqua rotate-45 animate-pulse-slow"></div>
  <div class="absolute bottom-20 right-[15%] w-8 h-8 bg-gold animate-pulse-slow"></div>
  <div class="absolute top-1/2 right-[8%] w-4 h-4 bg-coral rotate-12"></div>
  <div class="absolute bottom-1/3 left-[12%] w-5 h-5 bg-magenta rotate-45 animate-float"></div>

  <div class="container-k relative">
    <div class="max-w-5xl mx-auto text-center">
      <div class="chip mb-8 mx-auto">
        <span class="w-1.5 h-1.5 rounded-full bg-aqua"></span>
        Let's Build
      </div>
      <h2 class="heading-xl text-white mb-8">
        Enter. <span class="text-gradient">Expand.</span> Evolve.
      </h2>
      <p class="text-xl text-white/70 font-light max-w-2xl mx-auto mb-12">
        Partner with Kinvrs to build the digital infrastructure of tomorrow.
        From resilient backends to creative platforms — we're ready when you are.
      </p>
      <div class="flex flex-wrap gap-4 justify-center mb-20">
        <a href="mailto:info@kinvrs.com" class="btn-primary">
          info@kinvrs.com
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="tel:+912225737424" class="btn-ghost">022 2573 7424</a>
      </div>

      {/* Address card */}
      <div class="glass p-8 max-w-xl mx-auto text-left">
        <div class="text-xs uppercase tracking-[0.3em] text-white/40 mb-3">Find us</div>
        <div class="text-white leading-relaxed">
          Office No: 9, Mountain Bridge CHS,<br/>
          Powai, JVLR, Mumbai – 400072
        </div>
      </div>
    </div>
  </div>
</section>
