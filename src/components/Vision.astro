---
---

<section id="vision" class="relative py-32 overflow-hidden">
  <div class="container-k relative">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      {/* Left: manifesto */}
      <div>
        <div class="chip mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
          Vision & Mission
        </div>
        <h2 class="heading-lg text-white mb-10">
          Architects of <span class="text-gradient-purple">possibility.</span>
        </h2>

        <div class="space-y-8">
          <div class="border-l-2 border-electric pl-6">
            <div class="text-xs uppercase tracking-[0.25em] text-electric mb-2 font-semibold">Vision</div>
            <p class="text-lg text-white/80 leading-relaxed font-light">
              To build future-ready technology infrastructure that unlocks new
              possibilities in play, creation and connection for the next
              generation of digital ecosystems.
            </p>
          </div>

          <div class="border-l-2 border-magenta pl-6">
            <div class="text-xs uppercase tracking-[0.25em] text-magenta mb-2 font-semibold">Mission</div>
            <p class="text-lg text-white/80 leading-relaxed font-light">
              To empower creators, communities, and partners with systems that
              combine reliable engineering, creative potential, and long-term
              resilience.
            </p>
          </div>
        </div>
      </div>

      {/* Right: decorative composition */}
      <div class="relative aspect-square max-w-lg mx-auto">
        <div class="absolute inset-0 rounded-3xl bg-kinvrs-gradient-radial glow-purple"></div>
        <div class="absolute inset-0 rounded-3xl bg-grid bg-grid-fade"></div>

        {/* Big K mark */}
        <div class="absolute inset-0 flex items-center justify-center p-16">
          <img
            src="/logos/mark-black-512w.png"
            srcset="/logos/mark-black-256w.png 256w, /logos/mark-black-512w.png 512w"
            sizes="(min-width:768px) 420px, 280px"
            width="512" height="517"
            alt="Kinvrs K"
            class="logo-white w-full h-full object-contain drop-shadow-2xl opacity-90"
            loading="lazy" decoding="async"
          />
        </div>

        {/* Floating accent squares */}
        <div class="absolute -top-4 -right-4 w-8 h-8 bg-aqua rotate-45 animate-float"></div>
        <div class="absolute -bottom-4 left-8 w-6 h-6 bg-coral animate-float" style="animation-delay:-2s"></div>
        <div class="absolute top-1/2 -left-4 w-5 h-5 bg-gold rotate-12 animate-float" style="animation-delay:-4s"></div>
      </div>
    </div>
  </div>
</section>
