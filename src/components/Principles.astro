---
const principles = [
  { n: '01', title: 'Imagination as infrastructure', body: 'We treat creative potential as a first-class engineering concern — not an afterthought.' },
  { n: '02', title: 'Precision over performance theatre', body: 'Craft-driven systems that hold up in production, not just in demos.' },
  { n: '03', title: 'Bold yet grounded', body: 'Future-facing ambition paired with operational discipline and long-term commitment.' },
  { n: '04', title: 'Open ecosystems', body: 'Composable building blocks — not walled gardens — so teams can move fast together.' },
];
---

<section class="relative py-32 bg-rich overflow-hidden">
  <div class="container-k">
    <div class="grid md:grid-cols-12 gap-12 mb-16">
      <div class="md:col-span-5">
        <div class="chip mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
          Principles
        </div>
        <h2 class="heading-lg text-white">
          How we <span class="text-gradient-purple">build.</span>
        </h2>
      </div>
      <p class="md:col-span-7 text-xl text-white/60 font-light leading-relaxed self-end">
        Four commitments that shape every system we ship — from the smallest
        API surface to the largest platform bet.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-px bg-white/10 border border-white/10 rounded-3xl overflow-hidden" data-reveal-stagger>
      {principles.map((p) => (
        <div class="bg-rich p-10 group hover:bg-electric/10 transition-colors duration-500 relative">
          <div class="font-mono text-xs text-white/30 mb-6">{p.n}</div>
          <h3 class="text-2xl md:text-3xl font-display font-bold text-white mb-4">{p.title}</h3>
          <p class="text-white/60 leading-relaxed">{p.body}</p>
          <div class="absolute top-10 right-10 w-2 h-2 bg-electric opacity-0 group-hover:opacity-100 transition"></div>
        </div>
      ))}
    </div>
  </div>
</section>
