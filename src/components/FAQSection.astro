---
import FAQ from './react/FAQ.tsx';
---

<section id="faq" class="relative py-32 bg-rich overflow-hidden">
  <div class="absolute inset-0 bg-grid bg-grid-fade opacity-30"></div>
  <div class="absolute top-20 right-10 w-64 h-64 bg-electric/10 blur-2xl rounded-full"></div>

  <div class="container-k relative">
    <div class="grid md:grid-cols-12 gap-12 mb-16">
      <div class="md:col-span-5">
        <div class="chip mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan2"></span>
          FAQ
        </div>
        <h2 class="heading-lg text-white" data-reveal="up">
          Questions, <span class="text-gradient-purple">answered.</span>
        </h2>
        <p class="mt-6 text-white/60 leading-relaxed max-w-sm" data-reveal="up">
          Everything you need to know before building on the Kinvrs platform.
          Can't find what you're looking for?
          <a href="mailto:info@kinvrs.com" class="text-white underline decoration-electric underline-offset-4 hover:text-aqua">
            Drop us a line.
          </a>
        </p>
      </div>

      <div class="md:col-span-7">
        <FAQ client:visible />
      </div>
    </div>
  </div>
</section>
