---
const primary = [
  { name: 'Electric Purple', hex: '#4207C5', bg: 'bg-electric' },
  { name: 'Rich Black', hex: '#040223', bg: 'bg-rich border border-white/10' },
  { name: 'Storm Blue', hex: '#26374A', bg: 'bg-storm' },
  { name: 'Kinvrs White', hex: '#FFFFFF', bg: 'bg-white' },
];
const secondary = [
  { name: 'Aquamarine', hex: '#61cea0', bg: 'bg-aqua' },
  { name: 'Light Cyan', hex: '#87eafa', bg: 'bg-cyan2' },
  { name: 'Coral', hex: '#e8462a', bg: 'bg-coral' },
  { name: 'Golden Yellow', hex: '#f1c44c', bg: 'bg-gold' },
  { name: 'Pale Red', hex: '#e5544e', bg: 'bg-pink2' },
  { name: 'Magenta', hex: '#df79e3', bg: 'bg-magenta' },
];
---

<section class="relative py-32 bg-rich overflow-hidden">
  <div class="container-k">
    <div class="flex flex-wrap items-end justify-between gap-6 mb-16">
      <div>
        <div class="chip mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-coral"></span>
          Brand System
        </div>
        <h2 class="heading-lg text-white">A palette built for <span class="text-gradient">bold expression.</span></h2>
      </div>
      <p class="text-white/60 max-w-md">
        Vibrant digital shades paired with refined, contrasting neutrals —
        the visual language of the Kinvrs universe.
      </p>
    </div>

    <div class="mb-6 text-xs uppercase tracking-[0.3em] text-white/40">Primary</div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {primary.map((c) => (
        <div class="group">
          <div class={`${c.bg} aspect-[4/5] rounded-2xl relative overflow-hidden`}>
            <div class="absolute bottom-4 left-4 right-4 flex items-end justify-between">
              <span class={`text-xs font-mono ${c.hex === '#FFFFFF' ? 'text-rich' : 'text-white'}`}>{c.hex}</span>
            </div>
          </div>
          <div class="mt-3 text-sm text-white/80">{c.name}</div>
        </div>
      ))}
    </div>

    <div class="mb-6 text-xs uppercase tracking-[0.3em] text-white/40">Secondary</div>
    <div class="grid grid-cols-3 md:grid-cols-6 gap-4">
      {secondary.map((c) => (
        <div>
          <div class={`${c.bg} aspect-square rounded-xl`}></div>
          <div class="mt-3 text-xs text-white/60 font-mono">{c.hex}</div>
          <div class="text-xs text-white/40">{c.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>
