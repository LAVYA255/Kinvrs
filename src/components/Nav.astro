---
import Logo from './Logo.astro';
---

<header id="site-nav" class="fixed top-0 inset-x-0 z-50 transition-colors duration-500">
  <div class="container-k">
    <nav class="nav-shell mt-4 flex items-center justify-between rounded-full border border-white/10 bg-rich/85 px-4 md:px-6 py-3 transition-colors duration-500">
      <a href="/" class="flex items-center gap-2" aria-label="Kinvrs home">
        <Logo variant="white" class="nav-logo h-6 md:h-7 w-auto transition-[filter] duration-500" />
      </a>
      <ul class="nav-links hidden md:flex items-center gap-8 text-sm font-medium tracking-wide text-white/70 transition-colors duration-500">
        <li><a href="#about" class="hover:text-white transition">About</a></li>
        <li><a href="#principles" class="hover:text-white transition">Principles</a></li>
        <li><a href="#vision" class="hover:text-white transition">Vision</a></li>
        <li><a href="#faq" class="hover:text-white transition">FAQ</a></li>
        <li><a href="#contact" class="hover:text-white transition">Contact</a></li>
      </ul>
      <a href="#contact" class="btn-primary !py-2 !px-5 text-sm">
        Get in Touch
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </nav>
  </div>
</header>

<style is:global>
  body.nav-light .nav-shell {
    background-color: rgba(255, 255, 255, 0.9);
    border-color: rgba(4, 2, 35, 0.1);
  }
  body.nav-light .nav-links {
    color: rgba(4, 2, 35, 0.7);
  }
  body.nav-light .nav-links a:hover { color: #040223; }
  body.nav-light .nav-logo { filter: none !important; }
</style>
